}


function deleteSub(id){
  const s=subs.find(x=>x.id===id);if(!s)return;
  subs=subs.filter(x=>x.id!==id);
  communities.forEach(c=>{c.sharedSubIds=c.sharedSubIds.filter(x=>x!==id);});
  renderSubs();
  renderMonthly();
  communities.forEach(c=>refreshCommItems(c));
  showToast(`"${s.name}" を削除しました`);
}

