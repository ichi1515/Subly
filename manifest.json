/* ════════════════════════════════════════
   MONTHLY SPENDING
   ════════════════════════════════════════ */

function renderMonthly(){
  const wrap = document.getElementById('monthly-rows');
  if(!wrap) return;
  wrap.innerHTML = '';

  const now = new Date();
  // 過去6ヶ月 + 今月 + 翌月 = 8ヶ月分
  const months = [];
  for(let i = -6; i <= 1; i++){
    const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
    months.push({ year: d.getFullYear(), month: d.getMonth() + 1 });
  }
  // 新しい月が上に来るよう逆順
  months.reverse();

  // 各月の支払いサブスクと合計を計算
  const rows = months.map(({year, month}) => {
    const paying = subs.filter(s => isPayingInMonth(s, year, month));
    const total = paying.reduce((a, s) => a + monthlyEquivalent(s, year, month), 0);
    return { year, month, paying, total };
  });

  const maxTotal = Math.max(...rows.map(r => r.total), 1);
  const isCurrentMonth = (y, m) => y === now.getFullYear() && m === now.getMonth() + 1;

  rows.forEach(({year, month, paying, total}) => {
    const rowId = `mrow-${year}-${month}`;
    const detailId = `mdetail-${year}-${month}`;
    const isCurrent = isCurrentMonth(year, month);
    const barPct = Math.round((total / maxTotal) * 100);
    const label = `${year === now.getFullYear() ? '' : year + '/'}${month}月`;

    const row = document.createElement('div');
    row.innerHTML = `
      <div class="monthly-row${isCurrent ? ' current' : ''}" id="${rowId}" onclick="toggleMonthDetail('${detailId}','${rowId}')">
        <div class="month-label">${label}${isCurrent ? ' ◀' : ''}</div>
        <div class="month-bar-wrap">
          <div class="month-bar-bg">
            <div class="month-bar-fill" style="width:${barPct}%"></div>
          </div>
          <span class="month-subs">${paying.length}件</span>
        </div>
        <div class="month-amount">${total ? '¥' + Math.round(total).toLocaleString() : '—'}</div>
      </div>
      <div class="month-detail" id="${detailId}">
        ${paying.length ? paying.map(s => `
          <div class="month-detail-item">
            <span class="month-detail-icon">${s.icon}</span>
            <span class="month-detail-name">${s.name}</span>
            <span class="month-detail-cycle">${cycleLabel[s.cycle]}</span>
            <span class="month-detail-price">¥${monthlyEquivalent(s, year, month).toLocaleString()}</span>
          </div>
        `).join('') : '<div style="padding:12px 18px;font-size:12px;color:var(--text3)">支払いなし</div>'}
      </div>
    `;
    wrap.appendChild(row);
  });

  // 今月は最初から展開
  const currentDetailId = `mdetail-${now.getFullYear()}-${now.getMonth()+1}`;
  const currentRowId    = `mrow-${now.getFullYear()}-${now.getMonth()+1}`;
  openMonthDetail(currentDetailId, currentRowId);
}

function toggleMonthDetail(detailId, rowId){
  const detail = document.getElementById(detailId);
  if(!detail) return;
  if(detail.classList.contains('open')){
    detail.classList.remove('open');
  } else {
    openMonthDetail(detailId, rowId);
  }
}

function openMonthDetail(detailId, rowId){
  const detail = document.getElementById(detailId);
  if(detail) detail.classList.add('open');
}

// そのサブスクがその月に支払いがあるかを判定
function isPayingInMonth(s, year, month){
  if(!s.date) return false;
  const start = s.startDate ? new Date(s.startDate) : new Date(s.date);
  const startY = start.getFullYear();
  const startM = start.getMonth() + 1;
  // 開始月より前は除外
  if(year < startY || (year === startY && month < startM)) return false;

  const nextPay = new Date(s.date);
  const cycle = s.cycle;

  // 毎月：必ず支払いあり
  if(cycle === 'monthly') return true;
  // 毎週：必ずあり
  if(cycle === 'weekly') return true;

  // 毎年：支払い月と一致するか
  if(cycle === 'yearly') return nextPay.getMonth() + 1 === month;

  // N ヶ月ごと
  const cycleMonths = { '2months':2, '3months':3, '6months':6 }[cycle];
  if(cycleMonths){
    // 次回支払い月から逆算して何ヶ月前かを計算
    const payM = nextPay.getMonth() + 1;
    const payY = nextPay.getFullYear();
    const diffMonths = (year - payY) * 12 + (month - payM);
    return diffMonths % cycleMonths === 0;
  }
  return false;
}

// その月に実際に支払う金額（週払いは月換算）
function monthlyEquivalent(s, year, month){
  if(s.cycle === 'weekly') return Math.round(s.price * 4.33);
  return s.price;
}

/* ════════════════════════════════════════
   AI ADVISOR (Claude API)
   ════════════════════════════════════════ */

async function runAiAdvice(){
  const list = document.getElementById('ai-advice-list');

  // ローディング表示
  list.innerHTML = `
    <div class="ai-loading">
      <div class="ai-loading-dots">
        <span></span><span></span><span></span>
      </div>
      <div class="ai-loading-text">サブスクを分析中...</div>
    </div>
  `;

  // コミュニティ内の全サービスを収集
  const communityItems = [];
  communities.forEach(c => {
    c.staticItems.forEach(x => {
      communityItems.push({
        community: c.name,
        name: x.name,
        who: x.who,
        price: x.price,
      });
    });
    subs.filter(s => c.sharedSubIds.includes(s.id)).forEach(s => {
      communityItems.push({
        community: c.name,
        name: s.name,
        who: '自分',
        price: `${s.currency}${s.price}`,
      });
    });
  });

  const subsData = subs.map(s => ({
    name: s.name,
    price: `${s.currency}${s.price}`,
    cycle: cycleLabel[s.cycle],
    category: s.category || 'その他',
    memo: s.memo || '',
  }));

  const prompt = `
あなたはサブスクリプション管理の節約アドバイザーです。
以下のユーザーのサブスク情報を分析して、節約アドバイスを提案してください。

【自分のサブスク】
${JSON.stringify(subsData, null, 2)}

【コミュニティ（家族・チーム）内のサブスク】
${JSON.stringify(communityItems, null, 2)}

以下の観点で分析してください：
1. プラン最適化：より安いプランへの切り替え提案（例：年払いへの変更、廉価プランへの変更）
2. 家族・グループプラン提案：コミュニティ内で同じカテゴリのサービスがある場合、ファミリープランへの統合提案

必ずJSON配列で返してください。他のテキストは一切含めないでください。
形式：
[
  {
    "icon": "絵文字1文字",
    "iconBg": "薄い背景色（例：#3ecf8e22）",
    "title": "アドバイスのタイトル（20文字以内）",
    "desc": "具体的な説明（60文字以内）",
    "saving": "節約できる金額（例：年間¥12,000節約）または null
  }
]
アドバイスは2〜4件。節約できる具体的な金額を必ず計算して含めてください。
データが少なくて提案がない場合は空配列[]を返してください。
`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }],
      }),
    });

    const data = await res.json();
    const raw = data.content?.find(b => b.type === 'text')?.text || '[]';
    const clean = raw.replace(/```json|```/g, '').trim();
    const advices = JSON.parse(clean);
    renderAiAdvices(advices);

  } catch(e) {
    list.innerHTML = `
      <div style="padding:24px 18px;text-align:center;color:var(--text3);font-size:13px">
        分析に失敗しました。再度お試しください。
      </div>
    `;
  }
}

function renderAiAdvices(advices){
  const list = document.getElementById('ai-advice-list');
  if(!advices.length){
    list.innerHTML = `
      <div style="padding:24px 18px;text-align:center;color:var(--text3);font-size:13px;line-height:1.7">
        🎉 現時点では特に改善できる点はありません！<br>サブスクを追加するとより詳しい分析ができます。
      </div>
    `;
    return;
  }
  list.innerHTML = '';
  advices.forEach(a => {
    const el = document.createElement('div');
    el.className = 'ai-advice-item';
    el.innerHTML = `
      <div class="ai-advice-icon" style="background:${a.iconBg||'rgba(108,99,255,0.15)'}">${a.icon}</div>
      <div class="ai-advice-body">
        <div class="ai-advice-title">${a.title}</div>
        <div class="ai-advice-desc">${a.desc}</div>
        ${a.saving ? `<span class="ai-saving">💰 ${a.saving}</span>` : ''}
      </div>
    `;
    list.appendChild(el);
  });
}

