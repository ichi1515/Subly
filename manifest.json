let obIcon = '📺';
let obCurrentStep = 0;

function initOnboarding(){
  // 初回のみ表示（localStorageで判定）
  const done = localStorage.getItem('subly_onboarded');
  if(done){
    document.getElementById('onboarding').style.display = 'none';
    return;
  }
  // デフォルト日付をセット
  const d = new Date(); d.setDate(d.getDate()+7);
  document.getElementById('ob-sub-date').value = d.toISOString().split('T')[0];

  // アイコンピッカー
  document.getElementById('ob-icon-row').addEventListener('click', e=>{
    const btn = e.target.closest('.ob-icon-btn'); if(!btn) return;
    document.querySelectorAll('.ob-icon-btn').forEach(b=>b.classList.remove('selected'));
    btn.classList.add('selected');
    obIcon = btn.dataset.icon;
  });
}

function obGoTo(step){
  // 現在のステップを非表示
  document.getElementById(`ob-step-${obCurrentStep}`).classList.remove('active');
  // ドット更新
  for(let i=0;i<3;i++){
    const dot = document.getElementById(`dot-${i}`);
    dot.classList.remove('active','done');
    if(i < step) dot.classList.add('done');
    else if(i === step) dot.classList.add('active');
  }
  obCurrentStep = step;
  document.getElementById(`ob-step-${step}`).classList.add('active');
}

function obNext(from){
  obGoTo(from + 1);
}

function obAddSub(){
  const name  = document.getElementById('ob-sub-name').value.trim();
  const price = parseInt(document.getElementById('ob-sub-price').value)||0;
  const cycle = document.getElementById('ob-sub-cycle').value;
  const date  = document.getElementById('ob-sub-date').value;
  const isTrial = cycle === 'trial';

  if(name){
    const colors = ['#6c63ff','#3ecf8e','#ff6584','#f5c542','#60a5fa','#f97316'];
    const color  = colors[Math.floor(Math.random()*colors.length)];
    subs.push({
      id:nextSubId++, name, icon:obIcon, color,
      price: isTrial ? 0 : price,
      currency:'¥', cycle, date,
      startDate: new Date().toISOString().split('T')[0],
      trialEnd: isTrial ? date : null,
      category:'その他', memo:'',
    });
  }
  obGoTo(2);
}

function obFinish(){
  // 名前をアバターに反映
  const name = document.getElementById('ob-name').value.trim();
  if(name){
    const avatar = document.querySelector('.avatar');
    if(avatar) avatar.textContent = name.charAt(0);
    document.getElementById('ob-done-title').textContent = `${name}さん、準備完了！`;
  }
  // 完了フラグ
  localStorage.setItem('subly_onboarded','1');
  localStorage.setItem('subly_username', name);
  // フェードアウト
  const ob = document.getElementById('onboarding');
  ob.classList.add('hidden');
  setTimeout(()=>{ ob.style.display='none'; }, 400);
  // メイン画面を再描画
  renderSubs();
  renderComms();
  renderMonthly();
}

