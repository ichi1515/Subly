<div class="toast" id="toast"></div>

<script>
/* ── DATA ── */
let subs = [];
let communities = [];
const cycleLabel={monthly:'毎月',yearly:'毎年','3months':'3ヶ月ごと','6months':'半年ごと','2months':'2ヶ月ごと',weekly:'毎週',trial:'無料体験中'};
const toMonthly={monthly:1,yearly:1/12,'3months':1/3,'6months':1/6,'2months':.5,weekly:4.33,trial:0};
let nextSubId=10,nextCommId=10;
let selIcon='📺',selColor='#6c63ff',selCommIcon='👨‍👩‍👧';
let manageTargetId=null;
let newCommChecked=new Set(),manageChecked=new Set();

/* ── RENDER SUBS ── */
function renderSubs(){
  const list=document.getElementById('sub-list');
  [...list.querySelectorAll('.sub-card')].forEach(el=>el.remove());
  document.getElementById('empty-state').style.display = subs.length?'none':'block';
  subs.forEach(s=>list.appendChild(buildSubCard(s)));
  updateSummary();
}
function buildSubCard(s){
  const el=document.createElement('div');
  el.className='sub-card';el.id='card-'+s.id;
  el.style.cursor='pointer';
  const isTrial = s.cycle === 'trial';
  const days=daysUntil(isTrial ? (s.trialEnd||s.date) : s.date);
  const bc = isTrial ? 'next-badge trial' : days<=3?'next-badge soon':'next-badge';
  const bt = isTrial
    ? (days<0 ? '体験終了' : days===0 ? '今日終了' : `体験残${days}日`)
    : (days===0?'今日':days<0?`${Math.abs(days)}日超過`:`${days}日後`);
  el.innerHTML=`
    <div class="sub-icon" style="background:${s.color}22">${s.icon}</div>
    <div class="sub-info">
      <div class="sub-name">${s.name}</div>
      <div class="sub-meta">
        <span class="cycle-badge">${cycleLabel[s.cycle]}</span>
        <span class="${bc}">${bt}</span>
      </div>
      ${isTrial ? `<div class="trial-price-hint">体験後 ${s.currency||'¥'}${(s.trialPrice||0).toLocaleString()}/${cycleLabel[s.trialCycle||'monthly']}</div>` : ''}
    </div>
    <div class="sub-price">${isTrial ? '<span style="color:var(--green);font-size:13px">無料</span>' : `${s.currency}${s.price.toLocaleString()}`}</div>
    <button class="btn-icon delete" onclick="event.stopPropagation();deleteSub(${s.id})">✕</button>
  `;
  el.addEventListener('click', ()=>openDetail(s.id));
  return el;
}

/* ── RENDER COMMUNITIES ── */
function renderComms(){
  const track=document.getElementById('comm-track');
  const dots=document.getElementById('comm-dots');
  track.innerHTML='';dots.innerHTML='';

  communities.forEach((c,i)=>{
    track.appendChild(buildCommCard(c));
    const d=document.createElement('div');
    d.className='dot'+(i===0?' active':'');
    d.onclick=()=>scrollToComm(i);
    dots.appendChild(d);
  });

  // +新規カード
  const add=document.createElement('div');
  add.className='community-add-card';
  add.innerHTML='<div class="add-icon">➕</div><p>新しいコミュニティを作成</p>';
  add.onclick=openNewCommModal;
  track.appendChild(add);
  const d=document.createElement('div');
  d.className='dot';
  d.onclick=()=>scrollToComm(communities.length);
  dots.appendChild(d);

  // スクロールでドット同期
  track.onscroll=()=>{
    const idx=Math.round(track.scrollLeft/track.offsetWidth);
    document.querySelectorAll('#comm-dots .dot').forEach((d,i)=>d.classList.toggle('active',i===idx));
  };

  updateSummary();
}

function buildCommCard(c){
  const card=document.createElement('div');
  card.className='community-card'+(c.active?'':' muted');
  card.id='comm-card-'+c.id;

  const avHTML=c.members.map(m=>`<div class="member-avatar" style="background:${m.color}">${m.name}</div>`).join('');

  card.innerHTML=`
    <div class="comm-header">
      <span class="comm-emoji">${c.emoji}</span>
      <span class="comm-name">${c.name}</span>
      <div class="member-avatars">${avHTML}</div>
      <button class="share-link-btn" onclick="copyInvite('${c.name}')">🔗 招待</button>
      <div class="comm-toggle" onclick="toggleComm(${c.id})">
        <span class="comm-toggle-label" id="ctlabel-${c.id}">${c.active?'共有中':'オフ'}</span>
        <div class="toggle-sw ${c.active?'on':''}" id="ctoggle-${c.id}"></div>
      </div>
    </div>
    <div id="citems-${c.id}"></div>
    <div class="comm-total">
      <span class="comm-total-label">
        合計 / 月
        <button class="share-link-btn" onclick="openManage(${c.id})">✏️ 共有編集</button>
      </span>
      <span class="comm-total-value" id="ctotal-${c.id}">¥0</span>
    </div>
  `;
  refreshCommItems(c);
  return card;
}

function refreshCommItems(c){
  const wrap=document.getElementById('citems-'+c.id);
  if(!wrap)return;
  wrap.innerHTML='';

  c.staticItems.forEach(x=>{
    const el=document.createElement('div');
    el.className='comm-item';
    el.innerHTML=`
      <div class="comm-item-icon" style="background:#1a1a2e">${x.icon}</div>
      <div class="comm-item-name">${x.name}</div>
      <div class="comm-item-who">${x.who}</div>
      <div class="comm-item-price">${x.price}</div>
    `;
    wrap.appendChild(el);
  });

  const myItems=subs.filter(s=>c.sharedSubIds.includes(s.id));
  myItems.forEach(s=>{
    const el=document.createElement('div');
    el.className='comm-item';
    el.innerHTML=`
      <div class="comm-item-icon" style="background:${s.color}22">${s.icon}</div>
      <div class="comm-item-name">${s.name}</div>
      <div class="comm-item-who" style="color:var(--accent)">自分が登録</div>
      <div class="comm-item-price">${s.currency}${s.price.toLocaleString()}</div>
    `;
    wrap.appendChild(el);
  });

  if(!wrap.children.length){
    wrap.innerHTML=`<div style="padding:20px 18px;font-size:13px;color:var(--text3)">共有されているサブスクはありません</div>`;
  }

  const myTotal=myItems.reduce((a,s)=>a+s.price,0);
  const stTotal=c.staticItems.reduce((a,x)=>a+(parseInt((x.price||'').replace(/[¥,]/g,''))||0),0);
  const tv=document.getElementById('ctotal-'+c.id);
  if(tv)tv.textContent=`¥${(myTotal+stTotal).toLocaleString()}`;
}

/* ── COMMUNITY TOGGLE ── */
function toggleComm(id){
  const c=communities.find(x=>x.id===id);if(!c)return;
  // オンにしようとしている場合はPremium必須
  if(!c.active && !isPremium){
    openPremiumModal();
    showToast('✦ サブスクの共有には Premium が必要です');
    return;
  }
  c.active=!c.active;
  const sw=document.getElementById('ctoggle-'+id);
  const lb=document.getElementById('ctlabel-'+id);
  const card=document.getElementById('comm-card-'+id);
  if(sw)sw.classList.toggle('on',c.active);
  if(lb)lb.textContent=c.active?'共有中':'オフ';
  if(card)card.classList.toggle('muted',!c.active);
  showToast(c.active?`"${c.name}" の共有をオンにしました`:`"${c.name}" の共有をオフにしました`);
}

/* ── SCROLL ── */
function scrollToComm(idx){
  const t=document.getElementById('comm-track');
  t.scrollTo({left:idx*t.offsetWidth,behavior:'smooth'});
}

/* ── ADD SUB ── */
function openAddSubModal(){
  const d=new Date();d.setDate(d.getDate()+7);
  document.getElementById('f-date').value=d.toISOString().split('T')[0];
  document.getElementById('f-trial-end').value=d.toISOString().split('T')[0];
  document.getElementById('f-cycle').value='monthly';
  document.getElementById('trial-fields').style.display='none';
  document.getElementById('f-date-group').style.display='block';
  document.getElementById('f-date-label').textContent='次の支払日';
  document.getElementById('modal-sub').classList.add('open');
}

function onCycleChange(){
  const isTrial = document.getElementById('f-cycle').value === 'trial';
  document.getElementById('trial-fields').style.display = isTrial ? 'block' : 'none';
  document.getElementById('f-date-group').style.display = isTrial ? 'none' : 'block';
}

function addSub(){
  const isTrial = document.getElementById('f-cycle').value === 'trial';
  const name    = document.getElementById('f-name').value.trim();
  const currency= document.getElementById('f-currency').value;
  const cycle   = document.getElementById('f-cycle').value;
  const date    = isTrial
    ? document.getElementById('f-trial-end').value
    : document.getElementById('f-date').value;
  const price   = isTrial ? 0 : parseInt(document.getElementById('f-price').value);
  if(!name || (!isTrial && !price) || !date){
    showToast('⚠️ 必要な項目を入力してください'); return;
  }
  const today = new Date().toISOString().split('T')[0];
  const newSub = {
    id:nextSubId++, name, icon:selIcon, color:selColor,
    price, currency, cycle, date,
    payMethod:document.getElementById('f-paymethod').value,
    payLast4 :document.getElementById('f-paylast4').value.trim(),
    memo     :document.getElementById('f-memo').value.trim(),
    category :document.getElementById('f-category').value,
    startDate:today,
  };
  if(isTrial){
    newSub.trialEnd   = date;
    newSub.trialPrice = parseInt(document.getElementById('f-trial-price').value)||0;
    newSub.trialCycle = document.getElementById('f-trial-cycle').value;
  }
  subs.push(newSub);
  closeModal('modal-sub');
  document.getElementById('f-name').value='';
  document.getElementById('f-price').value='';
  renderSubs();
  renderMonthly();
  showToast(isTrial ? `"${name}" の無料体験を追加しました 🎁` : `"${name}" を追加しました ✓`);
}

/* ── NEW COMMUNITY ── */
function onClickNewComm(){
  if(!isPremium){
    openPremiumModal();
    showToast('✦ コミュニティ作成には Premium が必要です');
    return;
  }
  openNewCommModal();
}

function openNewCommModal(){
  newCommChecked.clear();
  buildCheckList('sub-check-list',newCommChecked);
  document.getElementById('c-name').value='';
  document.getElementById('modal-comm').classList.add('open');
}
function buildCheckList(containerId,checkedSet){
  const wrap=document.getElementById(containerId);
  wrap.innerHTML='';
  if(!subs.length){
    wrap.innerHTML='<p style="font-size:13px;color:var(--text3)">サブスクがまだ登録されていません</p>';
    return;
  }
  subs.forEach(s=>{
    const el=document.createElement('div');
    el.className='sub-check-item'+(checkedSet.has(s.id)?' checked':'');
    el.innerHTML=`
      <div class="check-box">${checkedSet.has(s.id)?'✓':''}</div>
      <span class="ci">${s.icon}</span>
      <span class="cname">${s.name}</span>
      <span class="cprice">${s.currency}${s.price.toLocaleString()}</span>
    `;
    el.onclick=()=>{
      if(checkedSet.has(s.id))checkedSet.delete(s.id);
      else checkedSet.add(s.id);
      el.classList.toggle('checked',checkedSet.has(s.id));
      el.querySelector('.check-box').textContent=checkedSet.has(s.id)?'✓':'';
    };
    wrap.appendChild(el);
  });
}
function createComm(){
  const name=document.getElementById('c-name').value.trim();
  if(!name){showToast('⚠️ コミュニティ名を入力してください');return;}
  communities.push({
    id:nextCommId++,name,emoji:selCommIcon,active:true,
    sharedSubIds:[...newCommChecked],
    members:[{name:'田',color:'#3d3a6b'}],
    staticItems:[],
  });
  closeModal('modal-comm');
  renderComms();
  setTimeout(()=>scrollToComm(communities.length-1),120);
