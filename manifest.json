<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Subly — サブスク管理</title>
<!-- PWA -->
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#6c63ff">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Subly">
<link rel="apple-touch-icon" href="/icon/icon.svg">
<!-- OGP -->
<meta property="og:title" content="Subly — サブスク管理">
<meta property="og:description" content="サブスクをシンプルに管理・共有するアプリ">
<meta property="og:type" content="website">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0e0f13; --surface:#16181f; --surface2:#1e2029;
  --border:#2a2d38; --accent:#6c63ff; --accent2:#ff6584;
  --text:#e8eaf0; --text2:#8b8fa8; --text3:#555870;
  --green:#3ecf8e; --yellow:#f5c542; --red:#ff4d6a;
  --radius:14px; --radius-sm:8px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans JP',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

header{display:flex;align-items:center;justify-content:space-between;padding:20px 28px;border-bottom:1px solid var(--border);position:sticky;top:0;background:rgba(14,15,19,0.92);backdrop-filter:blur(12px);z-index:100;}
.logo{font-family:'DM Mono',monospace;font-size:20px;font-weight:500;letter-spacing:-0.5px;}
.logo span{color:var(--accent);}
.avatar{width:34px;height:34px;border-radius:50%;background:#2a2d38;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;cursor:pointer;}

.container{max-width:860px;margin:0 auto;padding:32px 24px;}

.summary{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:32px;}
.summary-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;}
.summary-card .label{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.summary-card .value{font-family:'DM Mono',monospace;font-size:26px;font-weight:500;}
.summary-card .value small{font-size:13px;color:var(--text2);font-family:'Noto Sans JP',sans-serif;}
.summary-card .sub{font-size:12px;color:var(--text3);margin-top:4px;}

.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.section-title{font-size:14px;font-weight:500;color:var(--text2);letter-spacing:0.5px;}
.btn-add{display:flex;align-items:center;gap:6px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius-sm);padding:8px 16px;font-size:13px;font-weight:500;font-family:'Noto Sans JP',sans-serif;cursor:pointer;transition:opacity .15s;}
.btn-add:hover{opacity:.85;}

.sub-list{display:flex;flex-direction:column;gap:10px;}
.sub-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;display:flex;align-items:center;gap:14px;transition:border-color .2s;animation:fadeIn .25s ease;}
.sub-card:hover{border-color:#3a3d50;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.sub-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.sub-info{flex:1;min-width:0;}
.sub-name{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sub-meta{font-size:12px;color:var(--text3);margin-top:3px;display:flex;align-items:center;gap:8px;}
.cycle-badge{background:var(--surface2);border-radius:4px;padding:1px 6px;font-size:11px;color:var(--text2);}
.sub-price{font-family:'DM Mono',monospace;font-size:15px;font-weight:500;white-space:nowrap;}
.btn-icon{background:none;border:none;color:var(--text3);cursor:pointer;padding:4px;border-radius:6px;font-size:15px;transition:color .15s,background .15s;display:flex;align-items:center;}
.btn-icon:hover{color:var(--text);background:var(--surface2);}
.btn-icon.delete:hover{color:var(--red);}
.next-badge{font-size:11px;padding:2px 7px;border-radius:4px;background:rgba(245,197,66,0.15);color:var(--yellow);white-space:nowrap;}
.next-badge.soon{background:rgba(255,77,106,0.15);color:var(--red);}
.next-badge.trial{background:rgba(62,207,142,0.15);color:var(--green);}
.trial-price-hint{font-size:11px;color:var(--text3);margin-top:2px;}
.empty{text-align:center;padding:48px 0;color:var(--text3);}
.empty .emoji{font-size:36px;margin-bottom:12px;}
.empty p{font-size:14px;line-height:1.8;}

/* ═══ COMMUNITIES ═══ */
.community-section{margin-top:36px;padding-bottom:40px;}

.community-track{
  display:flex;gap:16px;
  overflow-x:auto;
  scroll-snap-type:x mandatory;
  -webkit-overflow-scrolling:touch;
  scrollbar-width:none;
  padding-bottom:4px;
}
.community-track::-webkit-scrollbar{display:none;}

.community-dots{display:flex;gap:6px;align-items:center;justify-content:center;margin-top:14px;}
.dot{width:6px;height:6px;border-radius:50%;background:var(--border);cursor:pointer;transition:background .2s,width .2s,border-radius .2s;}
.dot.active{width:18px;border-radius:3px;background:var(--accent);}

/* 各コミュニティカード — min-width を 100% にして1枚ずつ表示 */
.community-card{
  min-width:100%;scroll-snap-align:start;
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius);overflow:hidden;flex-shrink:0;
  transition:opacity .3s,border-color .2s;
}
.community-card.muted{opacity:.5;}

.comm-header{
  display:flex;align-items:center;gap:10px;
  padding:14px 18px;border-bottom:1px solid var(--border);
  background:var(--surface2);flex-wrap:wrap;gap:8px;
}
.comm-emoji{font-size:18px;flex-shrink:0;}
.comm-name{font-size:13px;font-weight:500;flex:1;min-width:80px;}
.member-avatars{display:flex;}
.member-avatar{width:26px;height:26px;border-radius:50%;border:2px solid var(--surface);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;margin-left:-6px;}
.member-avatar:first-child{margin-left:0;}

/* コミュニティ 共有トグル */
.comm-toggle{display:flex;align-items:center;gap:6px;cursor:pointer;padding:2px 4px;border-radius:6px;transition:background .15s;}
.comm-toggle:hover{background:var(--border);}
.comm-toggle-label{font-size:11px;color:var(--text3);white-space:nowrap;}
.toggle-sw{position:relative;width:36px;height:20px;background:var(--border);border-radius:10px;transition:background .2s;cursor:pointer;flex-shrink:0;}
.toggle-sw.on{background:var(--accent);}
.toggle-sw::after{content:'';position:absolute;top:3px;left:3px;width:14px;height:14px;background:#fff;border-radius:50%;transition:transform .2s;}
.toggle-sw.on::after{transform:translateX(16px);}

.share-link-btn{background:none;border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text2);padding:5px 10px;font-size:11px;font-family:'Noto Sans JP',sans-serif;cursor:pointer;transition:all .15s;white-space:nowrap;}
.share-link-btn:hover{border-color:var(--accent);color:var(--accent);}

.comm-item{display:flex;align-items:center;gap:12px;padding:12px 18px;border-bottom:1px solid var(--border);}
.comm-item:last-child{border-bottom:none;}
.comm-item-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.comm-item-name{flex:1;font-size:13px;}
.comm-item-who{font-size:11px;color:var(--text3);white-space:nowrap;}
.comm-item-price{font-family:'DM Mono',monospace;font-size:13px;color:var(--text2);white-space:nowrap;}

.comm-total{padding:12px 18px;display:flex;justify-content:space-between;align-items:center;background:var(--surface2);border-top:1px solid var(--border);}
.comm-total-label{font-size:12px;color:var(--text2);display:flex;align-items:center;gap:8px;}
.comm-total-value{font-family:'DM Mono',monospace;font-size:15px;font-weight:500;color:var(--green);}

/* 「+新規」カード */
.community-add-card{
  min-width:100%;scroll-snap-align:start;
  background:var(--surface);border:1px dashed var(--border);
  border-radius:var(--radius);display:flex;flex-direction:column;
  align-items:center;justify-content:center;padding:60px 24px;
  gap:12px;cursor:pointer;transition:border-color .2s;flex-shrink:0;
}
.community-add-card:hover{border-color:var(--accent);}
.community-add-card .add-icon{font-size:32px;}
.community-add-card p{font-size:13px;color:var(--text3);}

/* ═══ MODALS ═══ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:200;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:28px;width:100%;max-width:420px;margin:0 16px;transform:translateY(10px);transition:transform .2s;max-height:88vh;overflow-y:auto;}
.modal-overlay.open .modal{transform:translateY(0);}
.modal-title{font-size:16px;font-weight:700;margin-bottom:22px;}
.form-group{margin-bottom:16px;}
.form-label{display:block;font-size:12px;color:var(--text2);margin-bottom:6px;letter-spacing:.3px;}
.form-input,.form-select{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'Noto Sans JP',sans-serif;font-size:14px;padding:10px 12px;outline:none;transition:border-color .15s;}
.form-input:focus,.form-select:focus{border-color:var(--accent);}
.form-select option{background:var(--surface);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.icon-picker{display:flex;gap:8px;flex-wrap:wrap;margin-top:4px;}
.icon-option{width:38px;height:38px;border-radius:8px;border:1px solid var(--border);background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;transition:border-color .15s,background .15s;}
.icon-option:hover,.icon-option.selected{border-color:var(--accent);background:rgba(108,99,255,0.15);}
.color-picker{display:flex;gap:8px;margin-top:4px;}
.color-option{width:26px;height:26px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:border-color .15s,transform .15s;}
.color-option:hover{transform:scale(1.15);}
.color-option.selected{border-color:#fff;}
.modal-footer{display:flex;gap:10px;margin-top:24px;}
.btn-cancel{flex:1;background:none;border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text2);font-family:'Noto Sans JP',sans-serif;font-size:14px;padding:10px;cursor:pointer;transition:all .15s;}
.btn-cancel:hover{border-color:var(--text3);color:var(--text);}
.btn-save{flex:2;background:var(--accent);border:none;border-radius:var(--radius-sm);color:#fff;font-family:'Noto Sans JP',sans-serif;font-size:14px;font-weight:500;padding:10px;cursor:pointer;transition:opacity .15s;}
.btn-save:hover{opacity:.85;}

/* サブスク選択チェックリスト */
.sub-check-list{display:flex;flex-direction:column;gap:8px;margin-top:6px;}
.sub-check-item{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:border-color .15s;}
.sub-check-item:hover{border-color:var(--accent);}
.sub-check-item.checked{border-color:var(--accent);background:rgba(108,99,255,0.08);}
.sub-check-item .ci{font-size:18px;flex-shrink:0;}
.sub-check-item .cname{flex:1;font-size:13px;}
.sub-check-item .cprice{font-family:'DM Mono',monospace;font-size:12px;color:var(--text2);}
.check-box{width:18px;height:18px;border-radius:4px;border:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;transition:background .15s,border-color .15s;}
.sub-check-item.checked .check-box{background:var(--accent);border-color:var(--accent);color:#fff;}

/* ═══ NOTIFICATION BELL ═══ */
.notif-bell{
  position:relative;background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;width:38px;height:38px;display:flex;align-items:center;
  justify-content:center;font-size:16px;cursor:pointer;transition:border-color .15s;
}
.notif-bell:hover{border-color:var(--accent);}
.notif-badge{
  position:absolute;top:-5px;right:-5px;
  background:var(--red);color:#fff;
  font-size:10px;font-weight:700;font-family:'DM Mono',monospace;
  min-width:18px;height:18px;border-radius:9px;
  display:flex;align-items:center;justify-content:center;
  padding:0 4px;border:2px solid var(--bg);
  animation:popIn .2s ease;
}
@keyframes popIn{from{transform:scale(0)}to{transform:scale(1)}}

/* ═══ NOTIFICATION PANEL ═══ */
.notif-panel{
  position:fixed;top:70px;right:20px;
  width:320px;max-height:480px;
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius);box-shadow:0 20px 60px rgba(0,0,0,.5);
  z-index:150;display:flex;flex-direction:column;
  opacity:0;pointer-events:none;transform:translateY(-8px) scale(.97);
  transition:opacity .2s,transform .2s;
}
.notif-panel.open{opacity:1;pointer-events:all;transform:translateY(0) scale(1);}

.notif-overlay{
  position:fixed;inset:0;z-index:140;
  display:none;
}
.notif-overlay.open{display:block;}

.notif-panel-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px;border-bottom:1px solid var(--border);
}
.notif-panel-title{font-size:14px;font-weight:600;}
.notif-clear-btn{background:none;border:none;color:var(--text3);font-size:12px;font-family:'Noto Sans JP',sans-serif;cursor:pointer;padding:2px 6px;border-radius:4px;transition:color .15s;}
.notif-clear-btn:hover{color:var(--text2);}
.notif-close-btn{background:none;border:none;color:var(--text3);font-size:14px;cursor:pointer;padding:2px 6px;border-radius:4px;transition:color .15s;}
.notif-close-btn:hover{color:var(--text);}

.notif-list{flex:1;overflow-y:auto;max-height:340px;}
.notif-list::-webkit-scrollbar{width:4px;}
.notif-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

.notif-empty{padding:32px 16px;text-align:center;font-size:13px;color:var(--text3);}

.notif-item{
  display:flex;align-items:flex-start;gap:10px;
  padding:12px 16px;border-bottom:1px solid var(--border);
  animation:fadeIn .2s ease;
  cursor:default;
}
.notif-item:last-child{border-bottom:none;}
.notif-item.unread{background:rgba(108,99,255,0.05);}
.notif-item .ni-icon{
  width:36px;height:36px;border-radius:9px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:18px;
}
.notif-item .ni-body{flex:1;min-width:0;}
.notif-item .ni-title{font-size:13px;font-weight:500;line-height:1.4;}
.notif-item .ni-desc{font-size:11px;color:var(--text3);margin-top:3px;}
.notif-item .ni-time{font-size:10px;color:var(--text3);white-space:nowrap;margin-top:4px;}
.notif-item .ni-dismiss{
  background:none;border:none;color:var(--text3);cursor:pointer;
  font-size:12px;padding:2px;border-radius:4px;transition:color .15s;flex-shrink:0;
}
.notif-item .ni-dismiss:hover{color:var(--red);}

/* 緊急度バー */
.notif-item .urgency-bar{
  width:3px;border-radius:2px;align-self:stretch;flex-shrink:0;
}

.notif-panel-footer{border-top:1px solid var(--border);}
.notif-permission{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 14px;gap:8px;
  background:rgba(108,99,255,0.06);
}
.notif-permission span{font-size:11px;color:var(--text2);line-height:1.4;}
.btn-enable-notif{
  flex-shrink:0;background:var(--accent);border:none;color:#fff;
  font-size:11px;font-family:'Noto Sans JP',sans-serif;
  padding:5px 10px;border-radius:6px;cursor:pointer;transition:opacity .15s;
}
.btn-enable-notif:hover{opacity:.85;}

/* 通知センターの日付区切り */
.notif-date-label{
  font-size:10px;color:var(--text3);text-transform:uppercase;
  letter-spacing:.8px;padding:8px 16px 4px;
}

@keyframes shake{0%,100%{transform:rotate(0)}20%{transform:rotate(-15deg)}40%{transform:rotate(15deg)}60%{transform:rotate(-10deg)}80%{transform:rotate(10deg)}}
.notif-bell.shake{animation:shake .5s ease;}

.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:10px 18px;font-size:13px;opacity:0;pointer-events:none;transition:all .25s;z-index:300;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ═══ DETAIL DRAWER ═══ */
.drawer-overlay{
  position:fixed;inset:0;
  background:rgba(0,0,0,0.6);
  z-index:250;
  opacity:0;pointer-events:none;
  transition:opacity .25s;
}
.drawer-overlay.open{opacity:1;pointer-events:all;}

.drawer{
  position:fixed;
  bottom:0;left:0;right:0;
  background:var(--surface);
  border-top:1px solid var(--border);
  border-radius:20px 20px 0 0;
  z-index:251;
  transform:translateY(100%);
  transition:transform .3s cubic-bezier(.32,.72,0,1);
  max-height:85vh;
  overflow-y:auto;
}
.drawer.open{transform:translateY(0);}

.drawer-handle{
  width:36px;height:4px;
  border-radius:2px;
  background:var(--border);
  margin:12px auto 0;
}

.drawer-header{
  display:flex;align-items:center;gap:14px;
  padding:20px 24px 16px;
  border-bottom:1px solid var(--border);
}
.drawer-icon{
  width:52px;height:52px;border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  font-size:26px;flex-shrink:0;
}
.drawer-title{font-size:18px;font-weight:700;}
.drawer-category{
  font-size:11px;color:var(--text2);
  background:var(--surface2);
  border-radius:4px;padding:2px 8px;
  margin-top:4px;display:inline-block;
}
.drawer-close{
  margin-left:auto;
  background:none;border:none;
  color:var(--text3);font-size:20px;
  cursor:pointer;padding:4px;
  border-radius:8px;
  transition:color .15s,background .15s;
  line-height:1;
}
.drawer-close:hover{color:var(--text);background:var(--surface2);}

/* 金額ハイライト */
.drawer-price-block{
  margin:20px 24px;
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:20px;
  display:flex;align-items:center;justify-content:space-between;
}
.drawer-price-main{
  font-family:'DM Mono',monospace;
  font-size:32px;font-weight:500;
  color:var(--text);
}
.drawer-price-main small{font-size:14px;color:var(--text2);font-family:'Noto Sans JP',sans-serif;}
.drawer-price-annual{
  text-align:right;
}
.drawer-price-annual .al{font-size:11px;color:var(--text3);margin-bottom:4px;}
.drawer-price-annual .av{
  font-family:'DM Mono',monospace;
  font-size:16px;font-weight:500;color:var(--text2);
}

/* 情報グリッド */
.drawer-info-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:10px;margin:0 24px 20px;
}
.info-tile{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius-sm);padding:14px;
}
.info-tile .it-label{font-size:11px;color:var(--text3);margin-bottom:6px;letter-spacing:.3px;}
.info-tile .it-value{font-size:14px;font-weight:500;color:var(--text);}
.info-tile .it-value.mono{font-family:'DM Mono',monospace;}

/* 支払い方法 */
.pay-card{
  margin:0 24px 20px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius);padding:16px 18px;
  display:flex;align-items:center;gap:14px;
}
.pay-brand-icon{
  width:44px;height:28px;
  border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;letter-spacing:.5px;
  flex-shrink:0;
}
.pay-info{flex:1;}
.pay-name{font-size:13px;font-weight:500;}
.pay-last4{font-size:12px;color:var(--text3);font-family:'DM Mono',monospace;margin-top:2px;}

/* メモ */
.drawer-memo{
  margin:0 24px 24px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius-sm);padding:14px;
  font-size:13px;color:var(--text2);line-height:1.7;
  min-height:48px;
}
.drawer-memo .memo-label{font-size:11px;color:var(--text3);margin-bottom:6px;}

/* 削除ボタン */
.drawer-delete-btn{
  display:block;width:calc(100% - 48px);
  margin:0 24px 32px;
  background:none;border:1px solid rgba(255,77,106,0.3);
  border-radius:var(--radius-sm);
  color:var(--red);font-family:'Noto Sans JP',sans-serif;
  font-size:14px;padding:12px;cursor:pointer;
  transition:background .15s,border-color .15s;
}
.drawer-delete-btn:hover{background:rgba(255,77,106,0.1);border-color:var(--red);}

@media(max-width:600px){
  .summary{grid-template-columns:1fr 1fr;}
  .summary .summary-card:last-child{grid-column:1/-1;}
  .comm-toggle-label{display:none;}
}

/* ═══ AD BANNER ═══ */
.ad-banner{
  display:flex;align-items:center;gap:12px;
  margin:24px 0;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:12px 16px;
  position:relative;
  overflow:hidden;
}
.ad-banner::before{
  content:'広告';
  position:absolute;top:6px;right:8px;
  font-size:9px;color:var(--text3);letter-spacing:.5px;
}
.ad-thumb{
  width:40px;height:40px;border-radius:10px;
  flex-shrink:0;display:flex;align-items:center;justify-content:center;
  font-size:20px;
}
.ad-body{flex:1;min-width:0;}
.ad-title{font-size:13px;font-weight:500;}
.ad-desc{font-size:11px;color:var(--text3);margin-top:2px;}
.ad-cta{
  background:var(--accent);color:#fff;
  border:none;border-radius:6px;
  padding:6px 12px;font-size:12px;
  font-family:'Noto Sans JP',sans-serif;
  cursor:pointer;white-space:nowrap;flex-shrink:0;
  transition:opacity .15s;
}
.ad-cta:hover{opacity:.85;}
.ad-close{
  background:none;border:none;color:var(--text3);
  font-size:14px;cursor:pointer;padding:2px;
  position:absolute;bottom:6px;right:8px;
  transition:color .15s;
}
.ad-close:hover{color:var(--text);}
.ad-banner.hidden{display:none;}

/* プレミアムバナー（広告の代わりに出る） */
.premium-upsell{
  display:flex;align-items:center;gap:14px;
  margin:24px 0;
  background:rgba(108,99,255,0.1);
  border:1px solid rgba(108,99,255,0.3);
  border-radius:var(--radius);
  padding:16px 18px;
  cursor:pointer;
  transition:border-color .2s;
}
.premium-upsell:hover{border-color:var(--accent);}
.premium-upsell.hidden{display:none;}
.pu-icon{font-size:24px;flex-shrink:0;}
.pu-body{flex:1;}
.pu-title{font-size:13px;font-weight:700;color:var(--text);}
.pu-desc{font-size:12px;color:var(--text2);margin-top:3px;}
.pu-price{
  font-family:'DM Mono',monospace;
  font-size:13px;font-weight:500;
  color:var(--accent);white-space:nowrap;
}

/* ═══ PREMIUM MODAL ═══ */
.premium-modal{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:18px;
  padding:0;
  width:100%;max-width:440px;
  margin:0 16px;
  transform:translateY(10px);
  transition:transform .2s;
  overflow:hidden;
  max-height:90vh;overflow-y:auto;
}
.modal-overlay.open .premium-modal{transform:translateY(0);}

.pm-hero{
  background:#2a2d38;
  padding:32px 28px 28px;
  text-align:center;
}
.pm-crown{font-size:40px;margin-bottom:12px;}
.pm-hero-title{font-size:22px;font-weight:700;color:#fff;margin-bottom:6px;}
.pm-hero-sub{font-size:13px;color:rgba(255,255,255,0.75);}

.pm-body{padding:24px 28px;}

.pm-features{display:flex;flex-direction:column;gap:12px;margin-bottom:24px;}
.pm-feature{
  display:flex;align-items:center;gap:12px;
  padding:12px 14px;
  background:var(--surface2);
  border-radius:var(--radius-sm);
}
.pm-feature-icon{font-size:20px;flex-shrink:0;}
.pm-feature-text{flex:1;}
.pm-feature-name{font-size:13px;font-weight:500;}
.pm-feature-desc{font-size:11px;color:var(--text3);margin-top:2px;}
.pm-feature-check{color:var(--green);font-size:16px;flex-shrink:0;}

.pm-plans{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;}
.pm-plan{
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:16px;
  cursor:pointer;
  transition:border-color .2s,background .2s;
  position:relative;
  text-align:center;
}
.pm-plan:hover,.pm-plan.selected{border-color:var(--accent);background:rgba(108,99,255,0.08);}
.pm-plan-badge{
  position:absolute;top:-10px;left:50%;transform:translateX(-50%);
  background:var(--accent);color:#fff;
  font-size:10px;font-weight:700;
  padding:2px 10px;border-radius:10px;
  white-space:nowrap;
}
.pm-plan-period{font-size:11px;color:var(--text3);margin-bottom:6px;}
.pm-plan-price{font-family:'DM Mono',monospace;font-size:22px;font-weight:500;}
.pm-plan-price small{font-size:12px;color:var(--text2);font-family:'Noto Sans JP',sans-serif;}
.pm-plan-note{font-size:11px;color:var(--text3);margin-top:4px;}

.pm-cta{
  width:100%;background:var(--accent);
  border:none;border-radius:var(--radius-sm);
  color:#fff;font-family:'Noto Sans JP',sans-serif;
  font-size:15px;font-weight:700;padding:14px;
  cursor:pointer;transition:opacity .15s;
  margin-bottom:12px;
}
.pm-cta:hover{opacity:.9;}
.pm-cancel-link{
  display:block;text-align:center;
  font-size:12px;color:var(--text3);
  cursor:pointer;padding:4px;
}
.pm-cancel-link:hover{color:var(--text2);}

/* プレミアムバッジ（加入後ヘッダーに表示） */
.premium-badge{
  display:none;
  background:var(--accent);
  color:#fff;font-size:11px;font-weight:700;
  padding:3px 10px;border-radius:10px;
  letter-spacing:.3px;
}

/* ═══ ADD TO HOME SCREEN GUIDE ═══ */
.a2hs-overlay{
  position:fixed;inset:0;
  background:rgba(0,0,0,0.85);
  z-index:400;
  display:flex;align-items:flex-end;
  opacity:0;pointer-events:none;
  transition:opacity .3s;
}
.a2hs-overlay.open{opacity:1;pointer-events:all;}

.a2hs-sheet{
  width:100%;
  background:var(--surface);
  border-top:1px solid var(--border);
  border-radius:20px 20px 0 0;
  padding:0 0 40px;
  transform:translateY(100%);
  transition:transform .35s cubic-bezier(.32,.72,0,1);
  max-height:92vh;
  overflow-y:auto;
}
.a2hs-overlay.open .a2hs-sheet{transform:translateY(0);}

.a2hs-handle{
  width:36px;height:4px;border-radius:2px;
  background:var(--border);
  margin:12px auto 0;
}
.a2hs-header{
  padding:20px 24px 16px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:14px;
}
.a2hs-app-icon{
  width:52px;height:52px;border-radius:14px;
  background:#0e0f13;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.a2hs-header-text{}
.a2hs-header-title{font-size:16px;font-weight:700;}
.a2hs-header-sub{font-size:12px;color:var(--text3);margin-top:3px;}
.a2hs-close{
  margin-left:auto;background:none;border:none;
  color:var(--text3);font-size:20px;cursor:pointer;
  padding:4px;border-radius:8px;
  transition:color .15s;
}
.a2hs-close:hover{color:var(--text);}

.a2hs-steps{
  padding:20px 24px;
  display:flex;flex-direction:column;gap:0;
}
.a2hs-step{
  display:flex;gap:16px;
  padding:16px 0;
  border-bottom:1px solid var(--border);
  position:relative;
}
.a2hs-step:last-child{border-bottom:none;}

.a2hs-step-num{
  width:28px;height:28px;border-radius:50%;
  background:var(--accent);
  color:#fff;font-size:13px;font-weight:700;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;margin-top:2px;
}
.a2hs-step-body{flex:1;}
.a2hs-step-title{font-size:14px;font-weight:600;margin-bottom:4px;}
.a2hs-step-desc{font-size:12px;color:var(--text2);line-height:1.7;}

/* ステップ内のUIイメージ */
.a2hs-ui{
  margin-top:10px;
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  padding:12px 14px;
  display:flex;align-items:center;gap:10px;
  font-size:12px;color:var(--text2);
}
.a2hs-ui-icon{font-size:20px;flex-shrink:0;}
.a2hs-ui-arrow{
  width:24px;height:24px;
  background:var(--accent);
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:12px;color:#fff;
  flex-shrink:0;
  animation:pulse 1.5s ease-in-out infinite;
}
@keyframes pulse{
  0%,100%{transform:scale(1);opacity:1;}
  50%{transform:scale(1.15);opacity:.8;}
}

.a2hs-note{
  margin:0 24px;
  padding:12px 16px;
  background:rgba(108,99,255,0.08);
  border:1px solid rgba(108,99,255,0.2);
  border-radius:var(--radius-sm);
  font-size:12px;color:var(--text2);
  line-height:1.7;
}

/* ヘッダーのガイドボタン */
.a2hs-trigger-btn{
  background:none;border:1px solid var(--border);
  border-radius:var(--radius-sm);
  color:var(--text2);font-size:11px;
  font-family:'Noto Sans JP',sans-serif;
  padding:5px 10px;cursor:pointer;
  transition:all .15s;white-space:nowrap;
}

/* ═══ NOTIFICATION SETTINGS MODAL ═══ */
.ns-section{margin-bottom:22px;}
.ns-section-title{
  font-size:11px;color:var(--text3);
  text-transform:uppercase;letter-spacing:.8px;
  margin-bottom:10px;
}
.ns-row{
  display:flex;align-items:center;
  padding:12px 0;
  border-bottom:1px solid var(--border);
  gap:12px;
}
.ns-row:last-child{border-bottom:none;}
.ns-row-icon{font-size:18px;flex-shrink:0;width:28px;text-align:center;}
.ns-row-body{flex:1;}
.ns-row-title{font-size:13px;font-weight:500;}
.ns-row-desc{font-size:11px;color:var(--text3);margin-top:2px;}
.ns-toggle{
  position:relative;width:40px;height:22px;
  background:var(--border);border-radius:11px;
  transition:background .2s;cursor:pointer;flex-shrink:0;
}
.ns-toggle.on{background:var(--accent);}
.ns-toggle::after{
  content:'';position:absolute;top:3px;left:3px;
  width:16px;height:16px;background:#fff;border-radius:50%;
  transition:transform .2s;
}
.ns-toggle.on::after{transform:translateX(18px);}
.ns-toggle.disabled{opacity:.35;pointer-events:none;}

/* タイミング選択 */
.ns-timing-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:8px;
  margin-top:8px;
}
.ns-timing-btn{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius-sm);
  color:var(--text2);font-family:'Noto Sans JP',sans-serif;
  font-size:12px;padding:8px 4px;
  cursor:pointer;text-align:center;transition:all .15s;
}
.ns-timing-btn.selected{
  border-color:var(--accent);
  background:rgba(108,99,255,0.12);
  color:var(--text);
}

/* 通知スタイル選択 */
.ns-style-grid{
  display:flex;flex-direction:column;gap:6px;
  margin-top:8px;
}
.ns-style-row{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
}
.ns-style-label{flex:1;font-size:13px;color:var(--text2);}
.ns-style-icon{font-size:16px;width:24px;text-align:center;}

/* ═══ AI ADVICE SECTION ═══ */
.ai-section{margin-top:36px;}

.ai-section-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;
}
.ai-section-title{
  display:flex;align-items:center;gap:8px;
  font-size:14px;font-weight:500;color:var(--text2);letter-spacing:.5px;
}
.ai-badge{
  font-size:10px;font-weight:700;
  background:var(--accent);
  color:#fff;padding:2px 8px;border-radius:10px;letter-spacing:.3px;
}

.ai-locked{
  background:var(--surface);
  border:1px dashed var(--border);
  border-radius:var(--radius);
  padding:32px 24px;
  text-align:center;
  cursor:pointer;
  transition:border-color .2s;
}
.ai-locked:hover{border-color:var(--accent);}
.ai-locked-icon{font-size:32px;margin-bottom:12px;}
.ai-locked-title{font-size:14px;font-weight:600;margin-bottom:6px;}
.ai-locked-desc{font-size:13px;color:var(--text3);margin-bottom:16px;line-height:1.6;}
.ai-locked-btn{
  display:inline-block;
  background:var(--accent);
  color:#fff;border:none;border-radius:var(--radius-sm);
  padding:10px 24px;font-size:13px;font-weight:600;
  font-family:'Noto Sans JP',sans-serif;
  cursor:pointer;transition:opacity .15s;
}
.ai-locked-btn:hover{opacity:.85;}

/* アドバイスカード（生成後） */
.ai-result{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
}
.ai-result-header{
  display:flex;align-items:center;gap:10px;
  padding:14px 18px;
  background:rgba(108,99,255,0.08);
  border-bottom:1px solid var(--border);
}
.ai-result-title{font-size:13px;font-weight:600;flex:1;}
.ai-refresh-btn{
  background:none;border:1px solid var(--border);
  border-radius:6px;color:var(--text2);
  font-size:11px;font-family:'Noto Sans JP',sans-serif;
  padding:4px 10px;cursor:pointer;transition:all .15s;
}
.ai-refresh-btn:hover{border-color:var(--accent);color:var(--accent);}

.ai-advice-list{padding:4px 0;}

.ai-advice-item{
  display:flex;gap:14px;
  padding:16px 18px;
  border-bottom:1px solid var(--border);
  animation:fadeIn .3s ease;
}
.ai-advice-item:last-child{border-bottom:none;}
.ai-advice-icon{
  width:36px;height:36px;border-radius:9px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;margin-top:2px;
}
.ai-advice-body{flex:1;}
.ai-advice-title{font-size:13px;font-weight:600;margin-bottom:4px;}
.ai-advice-desc{font-size:12px;color:var(--text2);line-height:1.6;}
.ai-saving{
  display:inline-block;margin-top:6px;
  background:rgba(62,207,142,0.15);color:var(--green);
  font-size:11px;font-weight:700;font-family:'DM Mono',monospace;
  padding:2px 8px;border-radius:4px;
}

/* ローディングアニメ */
.ai-loading{
  padding:32px 18px;
  display:flex;flex-direction:column;align-items:center;gap:14px;
}
.ai-loading-dots{display:flex;gap:6px;}
.ai-loading-dots span{
  width:8px;height:8px;border-radius:50%;
  background:var(--accent);
  animation:dotPulse 1.2s ease-in-out infinite;
}
.ai-loading-dots span:nth-child(2){animation-delay:.2s;}
.ai-loading-dots span:nth-child(3){animation-delay:.4s;}
@keyframes dotPulse{
  0%,80%,100%{opacity:.2;transform:scale(.8);}
  40%{opacity:1;transform:scale(1);}
}
.ai-loading-text{font-size:13px;color:var(--text3);}

/* ═══ MONTHLY HISTORY ═══ */
.monthly-section{margin-top:36px;padding-bottom:40px;}

.monthly-table{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
}
.monthly-table-header{
  display:grid;
  grid-template-columns:80px 1fr auto;
  padding:10px 18px;
  background:var(--surface2);
  border-bottom:1px solid var(--border);
  font-size:11px;color:var(--text3);
  letter-spacing:.5px;text-transform:uppercase;
}
.monthly-row{
  display:grid;
  grid-template-columns:80px 1fr auto;
  align-items:center;
  padding:14px 18px;
  border-bottom:1px solid var(--border);
  transition:background .15s;
  cursor:pointer;
}
.monthly-row:last-child{border-bottom:none;}
.monthly-row:hover{background:var(--surface2);}
.monthly-row.current .month-label{color:var(--accent);font-weight:700;}

.month-label{
  font-family:'DM Mono',monospace;
  font-size:13px;color:var(--text2);
}
.month-bar-wrap{
  padding:0 16px 0 8px;
  display:flex;align-items:center;gap:10px;
}
.month-bar-bg{
  flex:1;height:6px;
  background:var(--border);
  border-radius:3px;overflow:hidden;
}
.month-bar-fill{
  height:100%;border-radius:3px;
  background:var(--accent);
  transition:width .5s ease;
}
.month-subs{font-size:11px;color:var(--text3);white-space:nowrap;}
.month-amount{
  font-family:'DM Mono',monospace;
  font-size:14px;font-weight:500;
  color:var(--text);white-space:nowrap;
}

/* 月タップで展開される内訳 */
.month-detail{
  display:none;
  background:var(--surface2);
  border-top:1px solid var(--border);
}
.month-detail.open{display:block;}
.month-detail-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 18px 10px 26px;
  border-bottom:1px solid var(--border);
  font-size:12px;
}
.month-detail-item:last-child{border-bottom:none;}
.month-detail-icon{font-size:15px;width:24px;text-align:center;flex-shrink:0;}
.month-detail-name{flex:1;color:var(--text2);}
.month-detail-cycle{color:var(--text3);font-size:11px;}
.month-detail-price{
  font-family:'DM Mono',monospace;
  font-size:12px;color:var(--text2);
}
/* ═══ ONBOARDING ═══ */
.onboarding{
  position:fixed;inset:0;
  background:var(--bg);
  z-index:500;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:32px 24px;
  transition:opacity .4s;
}
.onboarding.hidden{opacity:0;pointer-events:none;}

/* ステップインジケーター */
.ob-steps{
  display:flex;gap:6px;margin-bottom:40px;
}
.ob-step-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--border);transition:all .3s;
}
.ob-step-dot.active{width:20px;border-radius:3px;background:var(--accent);}
.ob-step-dot.done{background:var(--accent);opacity:.4;}

/* 各ステップのコンテンツ */
.ob-screen{
  width:100%;max-width:400px;
  display:none;flex-direction:column;align-items:center;
  text-align:center;
  animation:fadeIn .3s ease;
}
.ob-screen.active{display:flex;}

.ob-emoji{font-size:56px;margin-bottom:20px;}
.ob-title{font-size:22px;font-weight:700;margin-bottom:10px;}
.ob-desc{font-size:14px;color:var(--text2);line-height:1.7;margin-bottom:32px;}

.ob-input-wrap{width:100%;margin-bottom:14px;}
.ob-input{
  width:100%;background:var(--surface);
  border:1px solid var(--border);border-radius:var(--radius);
  color:var(--text);font-family:'Noto Sans JP',sans-serif;
  font-size:16px;padding:14px 16px;outline:none;
  transition:border-color .15s;text-align:center;
}
.ob-input:focus{border-color:var(--accent);}

.ob-btn{
  width:100%;background:var(--accent);
  border:none;border-radius:var(--radius);
  color:#fff;font-family:'Noto Sans JP',sans-serif;
  font-size:15px;font-weight:600;padding:14px;
  cursor:pointer;transition:opacity .15s;margin-bottom:12px;
}
.ob-btn:hover{opacity:.85;}
.ob-skip{
  background:none;border:none;
  color:var(--text3);font-family:'Noto Sans JP',sans-serif;
  font-size:13px;cursor:pointer;padding:8px;
  transition:color .15s;
}
.ob-skip:hover{color:var(--text2);}

/* STEP2 サブスク入力 */
.ob-sub-form{
  width:100%;text-align:left;
  display:flex;flex-direction:column;gap:10px;
  margin-bottom:20px;
}
.ob-form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.ob-label{font-size:11px;color:var(--text3);margin-bottom:4px;letter-spacing:.3px;}
.ob-select{
  width:100%;background:var(--surface);
  border:1px solid var(--border);border-radius:var(--radius-sm);
  color:var(--text);font-family:'Noto Sans JP',sans-serif;
  font-size:14px;padding:10px 12px;outline:none;
}
.ob-select option{background:var(--surface);}

/* アイコンピッカー（オンボーディング用） */
.ob-icon-row{
  display:flex;gap:8px;flex-wrap:wrap;
  justify-content:center;margin-bottom:4px;
}
.ob-icon-btn{
  width:40px;height:40px;border-radius:10px;
  border:1px solid var(--border);background:var(--surface);
  font-size:20px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:border-color .15s,background .15s;
}
.ob-icon-btn.selected{border-color:var(--accent);background:rgba(108,99,255,0.15);}

/* STEP3 完了画面 */
.ob-check{
  width:72px;height:72px;border-radius:50%;
  background:rgba(62,207,142,0.15);
  border:2px solid var(--green);
  display:flex;align-items:center;justify-content:center;
  font-size:32px;margin-bottom:20px;
}
</style>
</head>
<body>

<!-- ═══ ONBOARDING ═══ -->
<div class="onboarding" id="onboarding">

  <!-- ステップドット -->
  <div class="ob-steps">
    <div class="ob-step-dot active" id="dot-0"></div>
    <div class="ob-step-dot" id="dot-1"></div>
    <div class="ob-step-dot" id="dot-2"></div>
  </div>

  <!-- STEP 0: ようこそ -->
  <div class="ob-screen active" id="ob-step-0">
    <div class="ob-emoji">📋</div>
    <div class="ob-title">Sublyへようこそ</div>
    <div class="ob-desc">サブスクをシンプルに管理して<br>毎月の支出を把握しましょう</div>
    <div class="ob-input-wrap">
      <div class="ob-label" style="text-align:left;margin-left:4px">あなたの名前</div>
      <input class="ob-input" id="ob-name" type="text" placeholder="名前を入力" maxlength="10">
    </div>
    <button class="ob-btn" onclick="obNext(0)">はじめる →</button>
  </div>

  <!-- STEP 1: 最初のサブスクを登録 -->
  <div class="ob-screen" id="ob-step-1">
    <div class="ob-emoji">➕</div>
    <div class="ob-title">最初のサブスクを追加</div>
    <div class="ob-desc">よく使っているサービスを<br>1つ登録してみましょう</div>
    <div class="ob-sub-form">
      <div>
        <div class="ob-label">サービス名</div>
        <input class="ob-input" id="ob-sub-name" type="text" placeholder="例: Netflix、Spotify..." style="text-align:left;font-size:14px;padding:10px 12px">
      </div>
      <div>
        <div class="ob-label">アイコン</div>
        <div class="ob-icon-row" id="ob-icon-row">
          <div class="ob-icon-btn selected" data-icon="📺">📺</div>
          <div class="ob-icon-btn" data-icon="🎵">🎵</div>
          <div class="ob-icon-btn" data-icon="🎮">🎮</div>
          <div class="ob-icon-btn" data-icon="📚">📚</div>
          <div class="ob-icon-btn" data-icon="☁️">☁️</div>
          <div class="ob-icon-btn" data-icon="💪">💪</div>
          <div class="ob-icon-btn" data-icon="🎨">🎨</div>
          <div class="ob-icon-btn" data-icon="🧠">🧠</div>
        </div>
      </div>
      <div class="ob-form-row">
        <div>
          <div class="ob-label">月額</div>
          <input class="ob-input" id="ob-sub-price" type="number" placeholder="980" style="text-align:left;font-size:14px;padding:10px 12px">
        </div>
        <div>
          <div class="ob-label">サイクル</div>
          <select class="ob-select" id="ob-sub-cycle">
            <option value="monthly">毎月</option>
            <option value="yearly">毎年</option>
            <option value="3months">3ヶ月</option>
            <option value="6months">半年</option>
            <option value="weekly">毎週</option>
            <option value="trial">🎁 無料体験</option>
          </select>
        </div>
      </div>
      <div>
        <div class="ob-label">次の支払日</div>
        <input class="ob-input" id="ob-sub-date" type="date" style="text-align:left;font-size:14px;padding:10px 12px">
      </div>
    </div>
    <button class="ob-btn" onclick="obAddSub()">追加して次へ →</button>
    <button class="ob-skip" onclick="obNext(1)">あとで追加する</button>
  </div>

  <!-- STEP 2: 完了 -->
  <div class="ob-screen" id="ob-step-2">
    <div class="ob-check">✓</div>
    <div class="ob-title" id="ob-done-title">準備完了！</div>
    <div class="ob-desc">Sublyを使い始めましょう。<br>サブスクはいつでも追加・編集できます。</div>
    <button class="ob-btn" onclick="obFinish()">Sublyを始める 🚀</button>
  </div>

</div>
  <div class="logo">Sub<span>ly</span></div>
  <div style="display:flex;align-items:center;gap:10px">
    <button class="a2hs-trigger-btn" onclick="openA2HS()">📲 ホームに追加</button>
    <button class="notif-bell" id="notif-bell" onclick="toggleNotifPanel()" title="通知">
      🔔
      <span class="notif-badge" id="notif-badge" style="display:none">0</span>
    </button>
    <span class="premium-badge" id="premium-badge">✦ PREMIUM</span>
    <div class="avatar">👤</div>
  </div>
</header>

<!-- 通知パネル -->
<div class="notif-panel" id="notif-panel">
  <div class="notif-panel-header">
    <span class="notif-panel-title">通知</span>
    <div style="display:flex;gap:8px;align-items:center">
      <button class="notif-clear-btn" onclick="openNotifSettings()" title="通知設定">⚙️</button>
      <button class="notif-clear-btn" onclick="clearAllNotifs()">すべて消去</button>
      <button class="notif-close-btn" onclick="toggleNotifPanel()">✕</button>
    </div>
  </div>
  <div class="notif-list" id="notif-list">
    <div class="notif-empty">通知はありません</div>
  </div>
  <div class="notif-panel-footer">
    <div class="notif-permission" id="notif-permission-row" style="display:none">
      <span>ブラウザ通知を有効にすると、閉じていても届きます</span>
      <button class="btn-enable-notif" onclick="requestPermission()">有効にする</button>
    </div>
  </div>
</div>
<div class="notif-overlay" id="notif-overlay" onclick="toggleNotifPanel()"></div>

<div class="container">

  <!-- SUMMARY -->
  <div class="summary">
    <div class="summary-card">
      <div class="label">月額合計</div>
      <div class="value" id="monthly-total">¥0 <small>/月</small></div>
      <div class="sub" id="annual-hint">年間 ¥0</div>
    </div>
    <div class="summary-card">
      <div class="label">契約数</div>
      <div class="value" id="sub-count">0 <small>件</small></div>
      <div class="sub" id="comm-count-label">コミュニティ 0件</div>
    </div>
    <div class="summary-card">
      <div class="label">次の支払い</div>
      <div class="value" id="next-payment">—</div>
      <div class="sub" id="next-name">—</div>
    </div>
  </div>

  <!-- MY SUBS -->
  <div class="section-header">
    <div class="section-title">MY SUBSCRIPTIONS</div>
    <button class="btn-add" onclick="openAddSubModal()">＋ 追加</button>
  </div>
  <div class="sub-list" id="sub-list">
    <div class="empty" id="empty-state">
      <div class="emoji">📭</div>
      <p>まだサブスクが登録されていません<br>「追加」から登録しましょう</p>
    </div>
  </div>

  <!-- 広告バナー（無料プランのみ表示） -->
  <div class="ad-banner" id="ad-banner">
    <div class="ad-thumb" id="ad-thumb">🎌</div>
    <div class="ad-body">
      <div class="ad-title" id="ad-title">楽天カードで還元率アップ</div>
      <div class="ad-desc" id="ad-desc">サブスク払いで最大3%ポイント還元。年会費永年無料。</div>
    </div>
    <button class="ad-cta">詳しく見る</button>
    <button class="ad-close" onclick="rotateAd()">↻</button>
  </div>

  <!-- プレミアムアップセル（無料プランのみ表示） -->
  <div class="premium-upsell" id="premium-upsell" onclick="openPremiumModal()">
    <div class="pu-icon">✦</div>
    <div class="pu-body">
      <div class="pu-title">広告を非表示にする</div>
      <div class="pu-desc">Subly Premium でクリーンな体験を</div>
    </div>
    <div class="pu-price">¥180/月〜</div>
  </div>

  <!-- AI ADVICE SECTION -->
  <div class="ai-section">
    <div class="ai-section-header">
      <div class="ai-section-title">
        AI ADVISOR
        <span class="ai-badge">PREMIUM</span>
      </div>
    </div>

    <!-- 未加入状態 -->
    <div class="ai-locked" id="ai-locked" onclick="openPremiumModal()">
      <div class="ai-locked-icon">🤖</div>
      <div class="ai-locked-title">AIがあなたのサブスクを分析します</div>
      <div class="ai-locked-desc">プラン最適化・家族プランへの切り替えで<br>節約できる金額をAIが自動で提案します</div>
      <button class="ai-locked-btn">Premium で解放する →</button>
    </div>

    <!-- 加入後のAIアドバイス表示エリア -->
    <div class="ai-result" id="ai-result" style="display:none">
      <div class="ai-result-header">
        <span style="font-size:18px">🤖</span>
        <span class="ai-result-title">AIによる節約アドバイス</span>
        <button class="ai-refresh-btn" onclick="runAiAdvice()">↻ 再分析</button>
      </div>
      <div class="ai-advice-list" id="ai-advice-list">
        <!-- JSで生成 -->
      </div>
    </div>
  </div>

  <!-- COMMUNITIES -->
  <div class="community-section">
    <div class="section-header">
      <div class="section-title">COMMUNITIES</div>
    </div>

    <!-- 常に表示：参加・閲覧は無料 -->
    <div id="comm-unlocked">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <span style="font-size:12px;color:var(--text3)" id="comm-free-hint">作成・共有には <span style="color:var(--accent)">Premium</span> が必要です</span>
        <button class="btn-add" onclick="onClickNewComm()">＋ 新規作成</button>
      </div>
      <div class="community-track" id="comm-track"></div>
      <div class="community-dots" id="comm-dots"></div>
    </div>
  </div>

  <!-- MONTHLY HISTORY -->
  <div class="monthly-section">
    <div class="section-header">
      <div class="section-title">MONTHLY SPENDING</div>
    </div>
    <div class="monthly-table">
      <div class="monthly-table-header">
        <span>月</span>
        <span style="padding-left:8px">内訳</span>
        <span>合計</span>
      </div>
      <div id="monthly-rows"></div>
    </div>
  </div>

</div>

<!-- ADD SUB MODAL -->
<div class="modal-overlay" id="modal-sub">
  <div class="modal">
    <div class="modal-title">サブスクを追加</div>
    <div class="form-group">
      <label class="form-label">サービス名</label>
      <input class="form-input" id="f-name" type="text" placeholder="例: Netflix、Spotify...">
    </div>
    <div class="form-group">
      <label class="form-label">アイコン</label>
      <div class="icon-picker" id="icon-picker">
        <div class="icon-option selected" data-icon="📺">📺</div>
        <div class="icon-option" data-icon="🎵">🎵</div>
        <div class="icon-option" data-icon="📚">📚</div>
        <div class="icon-option" data-icon="🎮">🎮</div>
        <div class="icon-option" data-icon="☁️">☁️</div>
        <div class="icon-option" data-icon="🛒">🛒</div>
        <div class="icon-option" data-icon="💪">💪</div>
        <div class="icon-option" data-icon="🎨">🎨</div>
        <div class="icon-option" data-icon="📰">📰</div>
        <div class="icon-option" data-icon="🧠">🧠</div>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">カラー</label>
      <div class="color-picker" id="color-picker">
        <div class="color-option selected" style="background:#6c63ff" data-color="#6c63ff"></div>
        <div class="color-option" style="background:#ff6584" data-color="#ff6584"></div>
        <div class="color-option" style="background:#3ecf8e" data-color="#3ecf8e"></div>
        <div class="color-option" style="background:#f5c542" data-color="#f5c542"></div>
        <div class="color-option" style="background:#60a5fa" data-color="#60a5fa"></div>
        <div class="color-option" style="background:#f97316" data-color="#f97316"></div>
        <div class="color-option" style="background:#e879f9" data-color="#e879f9"></div>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group" style="margin-bottom:0">
        <label class="form-label">金額</label>
        <input class="form-input" id="f-price" type="number" placeholder="980">
      </div>
      <div class="form-group" style="margin-bottom:0">
        <label class="form-label">通貨</label>
        <select class="form-select" id="f-currency">
          <option value="¥">¥ 円</option>
          <option value="$">$ USD</option>
          <option value="€">€ EUR</option>
        </select>
      </div>
    </div>
    <div class="form-group" style="margin-top:16px">
      <label class="form-label">支払いサイクル</label>
      <select class="form-select" id="f-cycle" onchange="onCycleChange()">
        <option value="monthly">毎月</option>
        <option value="2months">2ヶ月ごと</option>
        <option value="3months">3ヶ月ごと</option>
        <option value="6months">半年ごと</option>
        <option value="yearly">毎年</option>
        <option value="weekly">毎週</option>
        <option value="trial">🎁 無料体験期間</option>
      </select>
    </div>
    <!-- 無料体験：体験終了日 + 体験後のサイクル -->
    <div id="trial-fields" style="display:none">
      <div class="form-group">
        <label class="form-label">体験終了日</label>
        <input class="form-input" id="f-trial-end" type="date">
      </div>
      <div class="form-group">
        <label class="form-label">体験後の料金（月額）</label>
        <input class="form-input" id="f-trial-price" type="number" placeholder="980">
      </div>
      <div class="form-group">
        <label class="form-label">体験後のサイクル</label>
        <select class="form-select" id="f-trial-cycle">
          <option value="monthly">毎月</option>
          <option value="yearly">毎年</option>
          <option value="3months">3ヶ月ごと</option>
          <option value="6months">半年ごと</option>
        </select>
      </div>
    </div>
    <div class="form-group" id="f-date-group">
      <label class="form-label" id="f-date-label">次の支払日</label>
      <input class="form-input" id="f-date" type="date">
    </div>
    <div class="form-group">
      <label class="form-label">カテゴリ</label>
      <select class="form-select" id="f-category">
        <option value="動画">動画</option>
        <option value="音楽">音楽</option>
        <option value="クリエイティブ">クリエイティブ</option>
        <option value="ストレージ">ストレージ</option>
        <option value="ゲーム">ゲーム</option>
        <option value="ニュース">ニュース</option>
        <option value="フィットネス">フィットネス</option>
        <option value="その他">その他</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">支払い方法</label>
      <select class="form-select" id="f-paymethod">
        <option value="visa">Visa</option>
        <option value="mastercard">Mastercard</option>
        <option value="amex">American Express</option>
        <option value="apple">Apple Pay</option>
        <option value="google">Google Pay</option>
        <option value="paypal">PayPal</option>
        <option value="bank">銀行振込</option>
        <option value="other">その他</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">カード下4桁（任意）</label>
      <input class="form-input" id="f-paylast4" type="text" maxlength="4" placeholder="1234">
    </div>
    <div class="form-group">
      <label class="form-label">メモ（任意）</label>
      <input class="form-input" id="f-memo" type="text" placeholder="例: 個人プラン、家族と共有...">
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('modal-sub')">キャンセル</button>
      <button class="btn-save" onclick="addSub()">保存する</button>
    </div>
  </div>
</div>

<!-- NEW COMMUNITY MODAL -->
<div class="modal-overlay" id="modal-comm">
  <div class="modal">
    <div class="modal-title">コミュニティを作成</div>
    <div class="form-group">
      <label class="form-label">コミュニティ名</label>
      <input class="form-input" id="c-name" type="text" placeholder="例: 田中家、チームA...">
    </div>
    <div class="form-group">
      <label class="form-label">絵文字アイコン</label>
      <div class="icon-picker" id="comm-icon-picker">
        <div class="icon-option selected" data-icon="👨‍👩‍👧">👨‍👩‍👧</div>
        <div class="icon-option" data-icon="👫">👫</div>
        <div class="icon-option" data-icon="👯">👯</div>
        <div class="icon-option" data-icon="💼">💼</div>
        <div class="icon-option" data-icon="🏠">🏠</div>
        <div class="icon-option" data-icon="⚽">⚽</div>
        <div class="icon-option" data-icon="🎓">🎓</div>
        <div class="icon-option" data-icon="🎉">🎉</div>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">共有するサブスクを選択（あとから変更できます）</label>
      <div class="sub-check-list" id="sub-check-list"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('modal-comm')">キャンセル</button>
      <button class="btn-save" onclick="createComm()">作成する</button>
    </div>
  </div>
</div>

<!-- MANAGE SHARED SUBS MODAL -->
<div class="modal-overlay" id="modal-manage">
  <div class="modal">
    <div class="modal-title" id="manage-title">共有サブスクを編集</div>
    <div class="form-group">
      <label class="form-label">このコミュニティで共有するサブスクを選択</label>
      <div class="sub-check-list" id="manage-check-list"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('modal-manage')">キャンセル</button>
      <button class="btn-save" onclick="saveManage()">保存する</button>
    </div>
  </div>
</div>

<!-- NOTIFICATION SETTINGS MODAL -->
<div class="modal-overlay" id="modal-notif-settings">
  <div class="modal">
    <div class="modal-title">通知設定</div>

    <!-- マスタースイッチ -->
    <div class="ns-section">
      <div class="ns-row" style="padding-top:0">
        <div class="ns-row-icon">🔔</div>
        <div class="ns-row-body">
          <div class="ns-row-title">通知をオンにする</div>
          <div class="ns-row-desc">オフにするとすべての通知が届きません</div>
        </div>
        <div class="ns-toggle on" id="ns-master" onclick="toggleNsMaster()"></div>
      </div>
    </div>

    <!-- 通知の種類 -->
    <div class="ns-section" id="ns-types-section">
      <div class="ns-section-title">通知の種類</div>
      <div class="ns-row">
        <div class="ns-row-icon">💳</div>
        <div class="ns-row-body">
          <div class="ns-row-title">支払い期日のリマインド</div>
          <div class="ns-row-desc">支払日が近づいたときに通知</div>
        </div>
        <div class="ns-toggle on" id="ns-payment" onclick="toggleNs('ns-payment','notifPayment')"></div>
      </div>
      <div class="ns-row">
        <div class="ns-row-icon">🎁</div>
        <div class="ns-row-body">
          <div class="ns-row-title">無料体験の終了アラート</div>
          <div class="ns-row-desc">体験期間終了前に通知</div>
        </div>
        <div class="ns-toggle on" id="ns-trial" onclick="toggleNs('ns-trial','notifTrial')"></div>
      </div>
      <div class="ns-row">
        <div class="ns-row-icon">🤖</div>
        <div class="ns-row-body">
          <div class="ns-row-title">AIアドバイスの提案</div>
          <div class="ns-row-desc">節約できるプランが見つかったときに通知（Premium）</div>
        </div>
        <div class="ns-toggle" id="ns-ai" onclick="toggleNs('ns-ai','notifAI')"></div>
      </div>
      <div class="ns-row">
        <div class="ns-row-icon">👥</div>
        <div class="ns-row-body">
          <div class="ns-row-title">コミュニティの更新</div>
          <div class="ns-row-desc">メンバーがサブスクを追加・変更したとき</div>
        </div>
        <div class="ns-toggle on" id="ns-community" onclick="toggleNs('ns-community','notifCommunity')"></div>
      </div>
    </div>

    <!-- 通知タイミング -->
    <div class="ns-section" id="ns-timing-section">
      <div class="ns-section-title">何日前に通知</div>
      <div class="ns-timing-grid" id="ns-timing-grid">
        <div class="ns-timing-btn" data-days="1" onclick="selectTiming(1)">前日</div>
        <div class="ns-timing-btn selected" data-days="3" onclick="selectTiming(3)">3日前</div>
        <div class="ns-timing-btn" data-days="7" onclick="selectTiming(7)">1週間前</div>
        <div class="ns-timing-btn" data-days="14" onclick="selectTiming(14)">2週間前</div>
      </div>
    </div>

    <!-- 通知スタイル -->
    <div class="ns-section" id="ns-style-section">
      <div class="ns-section-title">通知スタイル</div>
      <div class="ns-style-grid">
        <div class="ns-style-row">
          <div class="ns-style-icon">📢</div>
          <div class="ns-style-label">バナー通知</div>
          <div class="ns-toggle on" id="ns-banner" onclick="toggleNs('ns-banner','notifBanner')"></div>
        </div>
        <div class="ns-style-row">
          <div class="ns-style-icon">🔴</div>
