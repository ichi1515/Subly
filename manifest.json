  // AIアドバイス解放
  document.getElementById('ai-locked').style.display = 'none';
  document.getElementById('ai-result').style.display = 'block';
  runAiAdvice();
  const planText = selectedPlan==='yearly' ? '年間プラン (¥1,800)' : '月額プラン (¥180/月)';
  showToast(`✦ Premium 登録完了！${planText}`);
}

/* ════════════════════════════════════════
   NOTIFICATION SETTINGS
   ════════════════════════════════════════ */
let notifSettings = {
  master:        true,
  notifPayment:  true,
  notifTrial:    true,
  notifAI:       false,
  notifCommunity:true,
  notifBanner:   true,
  notifBadge:    true,
  notifSound:    false,
  timing:        3,
};

function openNotifSettings(){
  toggleNotifPanel(); // パネルを閉じる
  // 現在の設定を反映
  setToggleUI('ns-master',    notifSettings.master);
  setToggleUI('ns-payment',   notifSettings.notifPayment);
  setToggleUI('ns-trial',     notifSettings.notifTrial);
  setToggleUI('ns-ai',        notifSettings.notifAI);
  setToggleUI('ns-community', notifSettings.notifCommunity);
  setToggleUI('ns-banner',    notifSettings.notifBanner);
  setToggleUI('ns-badge',     notifSettings.notifBadge);
  setToggleUI('ns-sound',     notifSettings.notifSound);
  document.querySelectorAll('.ns-timing-btn').forEach(btn=>{
    btn.classList.toggle('selected', parseInt(btn.dataset.days)===notifSettings.timing);
  });
  updateNsMasterUI();
  document.getElementById('modal-notif-settings').classList.add('open');
}

function setToggleUI(id, on){
  const el = document.getElementById(id);
  if(el) el.classList.toggle('on', on);
}

function toggleNsMaster(){
  notifSettings.master = !notifSettings.master;
  setToggleUI('ns-master', notifSettings.master);
  updateNsMasterUI();
}

function updateNsMasterUI(){
  const disabled = !notifSettings.master;
  ['ns-types-section','ns-timing-section','ns-style-section'].forEach(id=>{
    const el = document.getElementById(id);
    if(el) el.style.opacity = disabled ? '0.35' : '1';
    if(el) el.style.pointerEvents = disabled ? 'none' : 'auto';
  });
}

function toggleNs(toggleId, settingKey){
  notifSettings[settingKey] = !notifSettings[settingKey];
  setToggleUI(toggleId, notifSettings[settingKey]);
}

function selectTiming(days){
  notifSettings.timing = days;
  document.querySelectorAll('.ns-timing-btn').forEach(btn=>{
    btn.classList.toggle('selected', parseInt(btn.dataset.days)===days);
  });
}

function saveNotifSettings(){
  closeModal('modal-notif-settings');
  showToast('通知設定を保存しました ✓');
}

/* ════════════════════════════════════════
   NOTIFICATION SYSTEM
   ════════════════════════════════════════ */

let notifications = []; // {id, subId, title, desc, urgency:'high'|'mid'|'low', time, read}
let notifIdSeq = 1;
let notifCheckInterval = null;

function initNotifications(){
  // ブラウザ通知の許可状態を確認
  if('Notification' in window && Notification.permission === 'default'){
    document.getElementById('notif-permission-row').style.display='flex';
  }
  // 起動直後に一度チェック
  checkUpcomingPayments();
  // 以降は1時間ごと（デモ用に30秒ごとに模擬）
  notifCheckInterval = setInterval(checkUpcomingPayments, 30000);
}

function checkUpcomingPayments(){
  subs.forEach(s=>{
    const isTrial = s.cycle === 'trial';
    const targetDate = isTrial ? (s.trialEnd || s.date) : s.date;
    const days = daysUntil(targetDate);
    if(days <= 3 && days >= -1){
      const key = `${s.id}_${targetDate}`;
      const alreadyNotified = notifications.some(n=>n.key===key);
      if(!alreadyNotified){
        addNotification(isTrial ? {...s, date: targetDate, _isTrial: true} : s, days, key);
      }
    }
  });
}

function addNotification(s, days, key){
  let urgency, title, desc;
  const isTrial = s._isTrial || s.cycle === 'trial';
  if(days < 0){
    urgency='high';
    title = isTrial
      ? `${s.icon} ${s.name} の無料体験が終了しています`
      : `${s.icon} ${s.name} の支払いが超過しています`;
    desc = isTrial
      ? `体験終了から${Math.abs(days)}日経過 — 解約を確認してください`
      : `${Math.abs(days)}日超過 — ${s.currency}${s.price.toLocaleString()}`;
  } else if(days === 0){
    urgency='high';
    title = isTrial
      ? `${s.icon} ${s.name} の無料体験が今日終わります`
      : `${s.icon} ${s.name} の支払い日は今日です`;
    desc = isTrial
      ? `継続する場合は${s.currency||'¥'}${(s.trialPrice||0).toLocaleString()}/${cycleLabel[s.trialCycle||'monthly']}の課金が始まります`
      : `${s.currency}${s.price.toLocaleString()} — 忘れずに！`;
  } else if(days === 1){
    urgency='mid';
    title = isTrial
      ? `${s.icon} ${s.name} の無料体験は明日終わります`
      : `${s.icon} ${s.name} の支払いは明日です`;
    desc = isTrial
      ? `解約する場合は今日中に手続きを`
      : `${s.currency}${s.price.toLocaleString()}`;
  } else {
    urgency='low';
    title = isTrial
      ? `${s.icon} ${s.name} の無料体験終了まで${days}日`
      : `${s.icon} ${s.name} の支払いが${days}日後です`;
    desc = isTrial
      ? `解約忘れに注意 — ${formatDate(s.date)}`
      : `${s.currency}${s.price.toLocaleString()} — ${formatDate(s.date)}`;
  }

  const notif = {
    id: notifIdSeq++,
    key,
    subId: s.id,
    title, desc, urgency,
    time: new Date(),
    read: false,
    icon: s.icon,
    color: s.color,
  };
  notifications.unshift(notif);

  // ブラウザ通知（許可済みの場合）
  if('Notification' in window && Notification.permission === 'granted'){
    new Notification('Subly — 支払いリマインド', {
      body: `${title}\n${desc}`,
      icon: '📅',
      tag: key,
    });
  }

  renderNotifPanel();
  // ベルをぷるぷる
  const bell = document.getElementById('notif-bell');
  bell.classList.add('shake');
  setTimeout(()=>bell.classList.remove('shake'), 600);
}

function renderNotifPanel(){
  const list = document.getElementById('notif-list');
  const badge = document.getElementById('notif-badge');
  const unread = notifications.filter(n=>!n.read).length;

  // バッジ
  if(unread > 0){
    badge.textContent = unread > 9 ? '9+' : unread;
    badge.style.display = 'flex';
  } else {
    badge.style.display = 'none';
  }

  // リスト
  if(notifications.length === 0){
    list.innerHTML = '<div class="notif-empty">通知はありません 🎉</div>';
    return;
  }

  list.innerHTML = '';
  notifications.forEach(n=>{
    const urgencyColor = n.urgency==='high' ? 'var(--red)' : n.urgency==='mid' ? 'var(--yellow)' : 'var(--accent)';
    const timeStr = formatTimeAgo(n.time);
    const el = document.createElement('div');
    el.className = 'notif-item' + (n.read?'':' unread');
    el.innerHTML=`
      <div class="urgency-bar" style="background:${urgencyColor}"></div>
      <div class="ni-icon" style="background:${n.color}22">${n.icon}</div>
      <div class="ni-body">
        <div class="ni-title">${n.title}</div>
        <div class="ni-desc">${n.desc}</div>
        <div class="ni-time">${timeStr}</div>
      </div>
      <button class="ni-dismiss" onclick="dismissNotif(${n.id})" title="消去">✕</button>
    `;
    el.addEventListener('click', e=>{
      if(e.target.classList.contains('ni-dismiss'))return;
      n.read=true;
      el.classList.remove('unread');
      renderNotifBadge();
    });
    list.appendChild(el);
  });
}

function renderNotifBadge(){
  const badge = document.getElementById('notif-badge');
  const unread = notifications.filter(n=>!n.read).length;
  if(unread > 0){
    badge.textContent = unread > 9 ? '9+' : unread;
    badge.style.display='flex';
  } else {
    badge.style.display='none';
  }
}

function dismissNotif(id){
  notifications = notifications.filter(n=>n.id!==id);
  renderNotifPanel();
}
function clearAllNotifs(){
  notifications=[];
  renderNotifPanel();
}

function toggleNotifPanel(){
  const panel = document.getElementById('notif-panel');
  const overlay = document.getElementById('notif-overlay');
  const isOpen = panel.classList.contains('open');
  panel.classList.toggle('open', !isOpen);
  overlay.classList.toggle('open', !isOpen);
  if(!isOpen){
    // パネルを開いたとき全部既読に
    notifications.forEach(n=>n.read=true);
    setTimeout(renderNotifBadge, 300);
  }
}

function requestPermission(){
  if(!('Notification' in window)){
    showToast('このブラウザは通知をサポートしていません');
    return;
  }
  Notification.requestPermission().then(p=>{
    if(p==='granted'){
      document.getElementById('notif-permission-row').style.display='none';
      showToast('✅ ブラウザ通知を有効にしました！');
    } else {
      showToast('⚠️ 通知が拒否されました。ブラウザ設定から許可してください');
    }
  });
}

function formatTimeAgo(date){
  const diff = Math.floor((Date.now() - date.getTime()) / 1000);
  if(diff < 60) return 'たった今';
  if(diff < 3600) return `${Math.floor(diff/60)}分前`;
  if(diff < 86400) return `${Math.floor(diff/3600)}時間前`;
  return `${Math.floor(diff/86400)}日前`;
}

/* ベルのシェイクアニメ */
initOnboarding();
renderSubs();
renderComms();
renderMonthly();
initNotifications();
initAds();

// ユーザー名復元
const _savedName = localStorage.getItem('subly_username');
if(_savedName){
  const _av = document.querySelector('.avatar');
  if(_av) _av.textContent = _savedName.charAt(0);
}

// Service Worker登録（PWA対応）
if('serviceWorker' in navigator){
  window.addEventListener('load', ()=>{
    navigator.serviceWorker.register('/sw.js')
      .catch(()=>{}); // 開発環境では無視
  });
}
</script>
