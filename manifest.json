function openDetail(id){
  const s=subs.find(x=>x.id===id);if(!s)return;

  // アイコン・タイトル
  document.getElementById('d-icon').style.background=s.color+'22';
  document.getElementById('d-icon').textContent=s.icon;
  document.getElementById('d-name').textContent=s.name;
  document.getElementById('d-category').textContent=s.category||'その他';

  // 金額
  const monthly=s.price*(toMonthly[s.cycle]||1);
  document.getElementById('d-price').innerHTML=`${s.currency}${s.price.toLocaleString()} <small>/${s.cycle==='monthly'?'月':s.cycle==='yearly'?'年':cycleLabel[s.cycle]}</small>`;
  document.getElementById('d-cycle-label').textContent=cycleLabel[s.cycle]+'払い';
  document.getElementById('d-annual').textContent=`${s.currency}${Math.round(monthly*12).toLocaleString()}`;

  // 日付
  const days=daysUntil(s.date);
  const nd=new Date(s.date);
  document.getElementById('d-nextdate').textContent=`${nd.getFullYear()}/${nd.getMonth()+1}/${nd.getDate()}`;
  document.getElementById('d-days').textContent=
    days===0?'今日！':days<0?`${Math.abs(days)}日超過`:`あと${days}日`;
  document.getElementById('d-days').style.color=
    days<0?'var(--red)':days<=3?'var(--yellow)':'var(--text)';

  // 開始日・利用期間
  const sd=s.startDate?new Date(s.startDate):null;
  if(sd){
    document.getElementById('d-startdate').textContent=`${sd.getFullYear()}/${sd.getMonth()+1}/${sd.getDate()}`;
    const months=Math.max(0,Math.round((new Date()-sd)/2629800000));
    document.getElementById('d-duration').textContent=
      months>=12?`${Math.floor(months/12)}年${months%12?months%12+'ヶ月':''}`:months+'ヶ月';
  } else {
    document.getElementById('d-startdate').textContent='—';
    document.getElementById('d-duration').textContent='—';
  }

  // 支払い方法
  const pm=s.payMethod||'other';
  const brand=PAY_BRANDS[pm]||PAY_BRANDS.other;
  const pIcon=document.getElementById('d-pay-icon');
  pIcon.style.background=brand.bg;pIcon.style.color=brand.color;
  pIcon.textContent=pm==='apple'?'🍎':brand.label;
  document.getElementById('d-pay-name').textContent=PAY_NAMES[pm]||pm;
  document.getElementById('d-pay-last4').textContent=s.payLast4?`**** **** **** ${s.payLast4}`:'カード番号未登録';

  // メモ
  document.getElementById('d-memo').textContent=s.memo||'メモはありません';

  // 削除ボタン
  document.getElementById('d-delete-btn').onclick=()=>{
    closeDrawer();
    setTimeout(()=>deleteSub(s.id),250);
  };

  document.getElementById('drawer-overlay').classList.add('open');
  document.getElementById('detail-drawer').classList.add('open');
}

function closeDrawer(){
  document.getElementById('drawer-overlay').classList.remove('open');
